/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model quiz_mappings {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quiz_id       String      @db.Uuid
  grade_id      String      @db.Uuid
  subject_id    String      @db.Uuid
  content_id    String      @db.Uuid
  subcontent_id String      @db.Uuid
  contents      contents    @relation(fields: [content_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  grades        grades      @relation(fields: [grade_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
