generator client {
  provider        = "prisma-client"
  output          = "./generated/prisma"
  previewFeatures = ["partialIndexes"]
  engineType      = "binary"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contents {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subject_id          String                @db.Uuid
  name                String                @db.VarChar(150)
  created_at          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  channel_assignments channel_assignments[]
  subjects            subjects              @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  quiz_assignments    quiz_assignments[]
  quiz_mappings       quiz_mappings[]
  subcontents         subcontents[]
  video_assignments   video_assignments[]

  @@unique([subject_id, name], map: "contents_subject_name_unique")
  @@index([subject_id], map: "idx_contents_subject")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model grades {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String                @unique @db.VarChar(50)
  sort_order          Int                   @unique
  created_at          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  channel_assignments channel_assignments[]
  grade_channels      grade_channels[]
  profiles            profiles[]
  quiz_assignments    quiz_assignments[]
  quiz_mappings       quiz_mappings[]
  subjects            subjects[]
  video_assignments   video_assignments[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profiles {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String             @db.Uuid
  grade_id         String             @db.Uuid
  profile_name     String             @db.VarChar(100)
  avatar_url       String?
  is_active        Boolean            @default(true)
  created_at       DateTime           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  coins            Int?               @default(30) @db.SmallInt
  favorite_quizzes favorite_quizzes[]
  likes            likes[]
  grades           grades             @relation(fields: [grade_id], references: [id], onUpdate: NoAction)
  users            users_metadata     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reports          reports[]
  watch_histories  watch_histories[]

  @@unique([user_id, profile_name], map: "unique_profile_per_user")
  @@index([user_id], map: "idx_profiles_user")
  @@schema("public")
}

model questions {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quiz_id        String   @db.Uuid
  question_text  String
  difficulty     String?  @default("easy") @db.VarChar(50)
  options        Json
  correct_answer String
  created_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  question_image String?
  quizzes        quizzes  @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([quiz_id], map: "idx_questions_quiz")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model quizzes {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String             @db.VarChar(255)
  is_general       Boolean            @default(false)
  created_at       DateTime           @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  favorite_quizzes favorite_quizzes[]
  questions        questions[]
  quiz_assignments quiz_assignments[]
  quiz_mappings    quiz_mappings[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subcontents {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content_id          String                @db.Uuid
  name                String                @db.VarChar(150)
  created_at          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  channel_assignments channel_assignments[]
  quiz_assignments    quiz_assignments[]
  quiz_mappings       quiz_mappings[]
  contents            contents              @relation(fields: [content_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  video_assignments   video_assignments[]

  @@unique([content_id, name], map: "subcontents_content_name_unique")
  @@index([content_id], map: "idx_subcontents_content")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subjects {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  grade_id            String                @db.Uuid
  name                String                @db.VarChar(100)
  created_at          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  channel_assignments channel_assignments[]
  contents            contents[]
  quiz_assignments    quiz_assignments[]
  quiz_mappings       quiz_mappings[]
  subject_channels    subject_channels[]
  grades              grades                @relation(fields: [grade_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  video_assignments   video_assignments[]

  @@unique([grade_id, name], map: "subjects_grade_name_unique")
  @@index([grade_id], map: "idx_subjects_grade")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model videos {
  id                String              @id @db.VarChar(50)
  title             String              @db.VarChar(255)
  channel_title     String?
  thumbnails        Json?
  cached_at         DateTime            @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  published_at      DateTime?           @db.Timestamptz(6)
  channel_id        String?             @db.VarChar(100)
  duration          Int                 @default(0)
  view_count        BigInt              @default(0)
  likes             likes[]
  reports           reports[]
  video_assignments video_assignments[]
  watch_histories   watch_histories[]

  @@index([channel_id], map: "idx_videos_channel_id")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model channels {
  id                  String                @id @db.VarChar(100)
  name                String                @db.VarChar(255)
  thumbnail_url       Json?
  created_at          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  type                String                @default("curricular") @db.VarChar(20)
  channel_assignments channel_assignments[]
  grade_channels      grade_channels[]
  subject_channels    subject_channels[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model favorite_quizzes {
  profile_id   String   @db.Uuid
  quiz_id      String   @db.Uuid
  favorited_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  profiles     profiles @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  quizzes      quizzes  @relation(fields: [quiz_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([profile_id, quiz_id])
  @@index([profile_id], map: "idx_favorite_quizzes_profile")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model grade_channels {
  grade_id   String   @db.Uuid
  channel_id String   @db.VarChar(100)
  channels   channels @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  grades     grades   @relation(fields: [grade_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([grade_id, channel_id])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subject_channels {
  subject_id String   @db.Uuid
  channel_id String   @db.VarChar(100)
  channels   channels @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subjects   subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([subject_id, channel_id])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model channel_assignments {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel_id    String       @db.VarChar(100)
  grade_id      String       @db.Uuid
  subject_id    String?      @db.Uuid
  content_id    String?      @db.Uuid
  subcontent_id String?      @db.Uuid
  created_at    DateTime     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  channels      channels     @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_channel_assignments_channels")
  contents      contents?    @relation(fields: [content_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_channel_assignments_contents")
  grades        grades       @relation(fields: [grade_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_channel_assignments_grades")
  subcontents   subcontents? @relation(fields: [subcontent_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_channel_assignments_subcontents")
  subjects      subjects?    @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_channel_assignments_subjects")

  @@unique([channel_id, grade_id, subject_id, content_id, subcontent_id], map: "channel_assignments_combination_key")
  @@index([grade_id], map: "idx_channel_assignments_grade")
  @@index([channel_id], map: "idx_channel_assignments_channel")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model likes {
  profile_id String   @db.Uuid
  video_id   String   @db.VarChar(50)
  liked_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  profiles   profiles @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  videos     videos   @relation(fields: [video_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([profile_id, video_id])
  @@schema("public")
}

